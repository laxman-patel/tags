# Copy to .env and fill in secrets

# Neon Postgres (app role + higher-privilege migrate role)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/tags?sslmode=require
DATABASE_MIGRATE_URL=postgresql://user:password@ep-xxx.neon.tech/tags?sslmode=require

# Fireworks inference — primary provider for opencode harness (Tags is Fireworks-only for now)
FIREWORKS_API_KEY=

SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (app_3FfR0nnlP8ivA14WOK4CGQvs0DP)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Admin access: assign org:admin in Clerk Organizations, or bootstrap with allowlists:
# ADMIN_USER_IDS=user_abc,user_def
# ADMIN_EMAILS=you@example.com

# Cron — required; set Authorization: Bearer <CRON_SECRET> on cron requests (Railway Cron)
CRON_SECRET=

# Inngest (durable run engine). Optional locally with the Inngest Dev Server.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# E2B — use the pre-built `opencode` template (https://e2b.dev/docs/agents/opencode)
# E2B_API_KEY=
# E2B_OPENCODE_TEMPLATE=opencode
# OPENCODE_MODEL=accounts/fireworks/models/kimi-k2-instruct
# GITHUB_TOKEN=   # optional, for private repo clones in the sandbox

# Cloudflare R2 (artifact bodies)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://artifacts.example.com

# Composio tool integrations (optional; toolkits per Space via enabledConnections)
# COMPOSIO_API_KEY=

# Seed defaults (optional)
SEED_SLACK_TEAM_ID=T00000000
SEED_SLACK_CHANNEL_ID=C00000000
SEED_SLACK_CHANNEL_NAME=tags-dev
SEED_MODEL_ID=accounts/fireworks/models/kimi-k2-instruct
