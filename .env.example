# Copy to .env and fill in secrets

# Neon Postgres (app role + higher-privilege migrate role)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/tags?sslmode=require
DATABASE_MIGRATE_URL=postgresql://user:password@ep-xxx.neon.tech/tags?sslmode=require

# Fireworks inference — primary provider for opencode harness (Tags is Fireworks-only for now)
FIREWORKS_API_KEY=

# Slack OAuth app credentials. Required in production for per-account workspace installs.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Base64-encoded 32-byte key for encrypted Slack installation tokens.
# Example generator: openssl rand -base64 32
TAGS_ENCRYPTION_KEY=
# Legacy/dev-only fallback. Production uses encrypted per-workspace OAuth tokens.
# SLACK_BOT_TOKEN=
# Public app URL — required in production (Slack OAuth redirect, run links, Inngest, MCP).
# Set to your Railway domain before building, e.g. https://tags-production.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk. Required in production for account ownership.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Inngest (durable run engine + schedule tick). Optional locally with the Inngest Dev Server.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# E2B — use the pre-built `opencode` template (https://e2b.dev/docs/agents/opencode)
# E2B_API_KEY=
# E2B_OPENCODE_TEMPLATE=opencode
# E2B_DEMO_TEMPLATE=tags-demo-desktop
# OPENCODE_MODEL=accounts/fireworks/routers/glm-5p2-fast

# Demo recording for coding PR runs. Requires E2B_API_KEY, COMPOSIO_API_KEY,
# an enabled GitHub Space connection, R2_PUBLIC_BASE_URL, and Slack files:write
# scope when enabled.
# DEMO_RECORDING_ENABLED=false
# DEMO_RECORDING_MAX_SECONDS=90
# DEMO_RECORDING_WIDTH=1280
# DEMO_RECORDING_HEIGHT=800
# DEMO_RECORDING_FPS=15

# Cloudflare R2 (artifact bodies)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://artifacts.example.com

# Sentry (optional — wired via instrumentation when set)
# SENTRY_DSN=

# Composio tool integrations (optional; toolkits per Space via enabledConnections)
# COMPOSIO_API_KEY=

# Seed defaults (optional)
SEED_SLACK_TEAM_ID=T00000000
SEED_SLACK_CHANNEL_ID=C00000000
SEED_SLACK_CHANNEL_NAME=tags-dev
SEED_MODEL_ID=accounts/fireworks/routers/glm-5p2-fast
