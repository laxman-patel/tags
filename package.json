{
  "name": "tags",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @tags/control-plane dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @tags/db generate",
    "db:migrate": "pnpm --filter @tags/db migrate",
    "db:seed": "pnpm --filter @tags/db seed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "proof-recording:sanity": "tsx scripts/proof-recording-sanity.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "shadcn": "^4.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.6.5"
}
